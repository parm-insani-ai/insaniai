# insani backend — environment variables
# Copy to .env and fill in your values

# Required
ANTHROPIC_API_KEY=sk-ant-your-key-here
JWT_SECRET=change-me-to-a-random-64-char-string

# Database
# Dev (SQLite):   sqlite+aiosqlite:///./insani.db
# Prod (Postgres): postgresql+asyncpg://user:pass@host:5432/insani
DATABASE_URL=sqlite+aiosqlite:///./insani.db

# CORS — comma-separated allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Environment: development | staging | production
ENV=development

# Optional: Sentry error tracking (get DSN from sentry.io)
SENTRY_DSN=

# Optional: Backup config
BACKUP_DIR=./backups
MAX_BACKUPS=48
BACKUP_S3_BUCKET=

# ── Integrations (OAuth credentials) ──

# Gmail / Google Workspace
# Get these from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/v1/integrations/callback/gmail

# QuickBooks (future)
# Get these from: https://developer.intuit.com
# QUICKBOOKS_CLIENT_ID=
# QUICKBOOKS_CLIENT_SECRET=
# QUICKBOOKS_REDIRECT_URI=http://localhost:8000/v1/integrations/callback/quickbooks

# Procore (future)
# Get these from: https://developers.procore.com
# PROCORE_CLIENT_ID=
# PROCORE_CLIENT_SECRET=
# PROCORE_REDIRECT_URI=http://localhost:8000/v1/integrations/callback/procore

# Autodesk (future)
# Get these from: https://aps.autodesk.com
# AUTODESK_CLIENT_ID=
# AUTODESK_CLIENT_SECRET=
# AUTODESK_REDIRECT_URI=http://localhost:8000/v1/integrations/callback/autodesk
